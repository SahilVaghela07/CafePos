# =========================================================================
# GLOBAL GITIGNORE CONFIGURATION
# Purpose: Prevents local dependencies, database files, and credentials from being committed to GitHub.
# =========================================================================

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Local database file storage
backend/data/
*.sqlite
*.sqlite-journal

# Environment secrets and credentials
.env
backend/.env
frontend/.env

# Build outputs
dist/
build/
.dist/

# OS-specific files
.DS_Store
Thumbs.db

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# IDE config folders
.idea/
.vscode/
